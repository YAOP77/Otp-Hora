NODE_ENV=development
PORT=3000
# PostgreSQL connection string for Prisma
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/otp_hora?schema=public"
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_CREATE_PER_WINDOW=30
# Cache succès auth API key (réduit bcrypt) — TTL ms, taille max entrées
API_KEY_CACHE_TTL_MS=300000
API_KEY_CACHE_MAX_ENTRIES=10000
USER_ACCESS_TOKEN_SECRET=change_me_access_secret
USER_REFRESH_TOKEN_SECRET=change_me_refresh_secret
USER_ACCESS_TOKEN_TTL_SECONDS=900
USER_REFRESH_TOKEN_TTL_SECONDS=604800
# Vérification email (JWT) + réinitialisation PIN
EMAIL_VERIFICATION_SECRET=change_me_email_verify_secret
EMAIL_VERIFICATION_TTL_SECONDS=86400
PIN_RESET_TOKEN_TTL_MINUTES=15
# URL publique de l’app (liens dans les emails mock)
PUBLIC_APP_URL=https://app.example.com
# URL publique du backend Hora (base des consent_url retournées aux entreprises)
# Défaut : PUBLIC_APP_URL si non défini
PUBLIC_HORA_URL=https://otp-hora.onrender.com
# JWT state pour les formulaires /flow/consent (anti-CSRF)
FLOW_STATE_SECRET=change_me_flow_state_secret
FLOW_STATE_TTL_SECONDS=900
# Optional: comma-separated origins for browser clients (omit to allow any origin)
# CORS_ORIGIN=https://app.example.com,https://admin.example.com
