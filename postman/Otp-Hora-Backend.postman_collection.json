        {
          "name": "[ENTREPRISE] POST Register (téléphone + PIN)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nom_entreprise\": \"Ma Société CI\",\n  \"phone\": \"+2250700000000\",\n  \"pin\": \"123456\"\n}"
            },
            "url": "{{base_url}}/enterprises/register",
            "description": "Inscription entreprise avec numéro international (E.164). Réponse 201 : `data` (profil), `api_key` (B2B), `auth` (access + refresh tokens entreprise). Exemple erreur : `PHONE_ALREADY_REGISTERED` (409)."
          }
        },
        {
          "name": "[ENTREPRISE] POST Login (téléphone + PIN)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"+2250700000000\",\n  \"pin\": \"123456\"\n}"
            },
            "url": "{{base_url}}/enterprises/login",
            "description": "Connexion application entreprise. Réponse 200 : `data` + `auth` (Bearer). En-têtes optionnels : `User-Agent`, `X-Device-Name` pour l'historique."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "try {",
                  "  const j = pm.response.json();",
                  "  if (j.auth && j.auth.access_token) {",
                  "    pm.collectionVariables.set('company_access_token', j.auth.access_token);",
                  "    pm.collectionVariables.set('company_refresh_token', j.auth.refresh_token);",
                  "  }",
                  "} catch (e) {}"
                ],
                "type": "text/javascript"
              }
