generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model users {
  user_id            String    @id @default(uuid()) @db.Uuid
  nom                String
  prenom             String
  pin_hash           String
  token_version      Int       @default(0)
  status             String
  role               String    @default("user")
  email              String?   @unique
  email_verified_at  DateTime?

  user_contacts        user_contacts[]
  user_devices         user_devices[]
  identity_links       identity_links[]
  recovery_methods     recovery_methods[]
  user_login_history   user_login_history[]
  pin_reset_tokens     pin_reset_tokens[]
}

model user_contacts {
  contact_id   String    @id @default(uuid()) @db.Uuid
  user_id      String    @db.Uuid
  phone_number String
  verified_at  DateTime?

  users users @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
}

model user_devices {
  device_id          String    @id @default(uuid()) @db.Uuid
  user_id            String    @db.Uuid
  device_fingerprint String
  trusted            Boolean
  device_name        String?
  user_agent         String?
  last_seen_at       DateTime?

  users users @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
}

model enterprise_accounts {
  company_id        String    @id @default(uuid()) @db.Uuid
  nom_entreprise    String
  api_key           String
  status            String
  phone_e164        String?   @unique
  pin_hash          String?
  token_version     Int       @default(0)
  deleted_at        DateTime?
  email             String?   @unique
  email_verified_at DateTime?

  identity_links                identity_links[]
  enterprise_devices            enterprise_devices[]
  enterprise_login_history      enterprise_login_history[]
  enterprise_pin_reset_tokens   enterprise_pin_reset_tokens[]
}

model enterprise_pin_reset_tokens {
  reset_id    String   @id @default(uuid()) @db.Uuid
  company_id  String   @db.Uuid
  token_hash  String
  expires_at  DateTime
  used_at     DateTime?
  created_at  DateTime @default(now())

  enterprise_accounts enterprise_accounts @relation(fields: [company_id], references: [company_id], onDelete: Cascade)

  @@index([company_id])
  @@index([token_hash])
}

model enterprise_devices {
  device_id          String @id @default(uuid()) @db.Uuid
  company_id         String @db.Uuid
  device_fingerprint String
  trusted            Boolean @default(false)
  device_name        String?
  user_agent         String?
  last_seen_at       DateTime?

  enterprise_accounts enterprise_accounts @relation(fields: [company_id], references: [company_id], onDelete: Cascade)

  @@unique([company_id, device_fingerprint])
}

model user_login_history {
  history_id   String   @id @default(uuid()) @db.Uuid
  user_id      String   @db.Uuid
  device_name  String?
  user_agent   String?
  connected_at DateTime @default(now())

  users users @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@index([user_id, connected_at])
}

model enterprise_login_history {
  history_id   String   @id @default(uuid()) @db.Uuid
  company_id   String   @db.Uuid
  device_name  String?
  user_agent   String?
  connected_at DateTime @default(now())

  enterprise_accounts enterprise_accounts @relation(fields: [company_id], references: [company_id], onDelete: Cascade)

  @@index([company_id, connected_at])
}

model pin_reset_tokens {
  reset_id    String    @id @default(uuid()) @db.Uuid
  user_id     String    @db.Uuid
  token_hash  String
  expires_at  DateTime
  used_at     DateTime?
  created_at  DateTime  @default(now())

  users users @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@index([user_id])
  @@index([token_hash])
}

model identity_links {
  link_id      String @id @default(uuid()) @db.Uuid
  company_id   String @db.Uuid
  user_id      String? @db.Uuid
  external_ref String
  status       String

  enterprise_accounts enterprise_accounts @relation(fields: [company_id], references: [company_id], onDelete: Cascade)
  users               users?              @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  auth_requests       auth_requests[]

  @@unique([user_id, company_id])
  @@unique([company_id, external_ref])
}

model auth_requests {
  request_id String   @id @default(uuid()) @db.Uuid
  link_id    String   @db.Uuid
  status     String
  expires_at DateTime

  identity_links identity_links @relation(fields: [link_id], references: [link_id], onDelete: Cascade)
  auth_events    auth_events[]
}

model auth_events {
  event_id   String   @id @default(uuid()) @db.Uuid
  request_id String   @db.Uuid
  action     String
  created_at DateTime @default(now())

  auth_requests auth_requests @relation(fields: [request_id], references: [request_id], onDelete: Cascade)
}

model recovery_methods {
  recovery_id String @id @default(uuid()) @db.Uuid
  user_id     String @db.Uuid
  method_type String
  status      String

  users users @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
}
